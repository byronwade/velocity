{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Velocity",
  "version": "0.1.0",
  "identifier": "com.byronwade.velocity",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5199",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Velocity",
        "width": 1440,
        "height": 920,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
